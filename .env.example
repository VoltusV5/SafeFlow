# Telegram
BOT_TOKEN=123456:ABC-DEF...
BOT_PASSWORD=your_secret_gate_password

# Comma-separated Telegram user IDs (numeric)
ADMIN_IDS=123456789,987654321

# Аватар при systemd start/stop (scripts/set_bot_avatar.py). Пусто = Src/«ава для бота.png» и Src/«бот на починке.jpg»
# BOT_AVATAR_ONLINE=/path/to/online.jpg
# BOT_AVATAR_OFFLINE=/path/to/offline.jpg

# Donation Alerts (от 10 ₽). Допускается старое имя DONATION_URL.
DONATION_ALERTS_URL=https://www.donationalerts.com/r/your_page

# Tribute — веб и ссылка t.me/... (от 100 ₽; подписка настраивается у Tribute)
TRIBUTE_URL_WEB=https://t.me/tribute/app?startapp=...
TRIBUTE_URL_TG=https://t.me/tribute/app?startapp=...

# SQLite (для systemd лучше абсолютный путь: четыре слэша после colon)
DATABASE_URL=sqlite+aiosqlite:////root/vpn-telegram-bot/bot_data.db

# --- AmneziaWG: scripts/generate_peer.sh ---
# Пусто GENERATE_PEER_SCRIPT = заглушка в keygen.
# REPLACE_ACTIVE_KEY_ON_NEW=false — на работающем сервере не инвалидировать старые записи в БД.
REPLACE_ACTIVE_KEY_ON_NEW=false
GENERATE_PEER_SCRIPT=/root/vpn-telegram-bot/scripts/generate_peer.sh
MAX_AMNEZIA_KEYS_PER_24H=50

# Вариант A — Amnezia в Docker (рекомендуется для VPS с amnezia-awg):
AWG_DOCKER_CONTAINER=amnezia-awg
AWG_WG_IFACE=wg0
AWG_WG_CONF=/opt/amnezia/awg/wg0.conf
WG_ENDPOINT=YOUR_PUBLIC_IP:41241
# Можно оставить пустым — скрипт прочитает public key из «wg show» в контейнере
WG_SERVER_PUBLIC_KEY=
WG_CLIENT_DNS=1.1.1.1
WG_SHARE_DNS2=1.0.0.1
AMNEZIA_SHARE_DESCRIPTION=SafeFlow
AWG_CLIENT_MTU=1376
# Подсеть клиентов как в Amnezia (часто 10.8.1.x для AWG)
WG_CLIENT_IP_PREFIX=10.8.1

# Параллельный Amnezia AWG для новых ключей (отдельный Docker, порт и подсеть). Пока пусто — выдача идёт в AWG_DOCKER_CONTAINER.
# AWG2_DOCKER_CONTAINER=amnezia-awg-20
# AWG2_WG_IFACE=wg0
# AWG2_WG_CONF=/opt/amnezia/awg/wg0.conf
# WG2_ENDPOINT=YOUR_PUBLIC_IP:41242
# WG2_CLIENT_IP_PREFIX=10.8.2
# WG2_SERVER_PUBLIC_KEY=
#
# Прочие протоколы Amnezia (Xray, OpenVPN, Cloak, WireGuard, IPsec, SS) живут в своих контейнерах.
# Их .env-переменные (DOCKER_*_CONTAINER, порты, CLEAN_XRAY_*) при добавлении AWG2 не меняйте —
# старые vpn:// ключи продолжают ссылаться на те же контейнеры и файлы внутри них.

# Вариант B — awg/wg на хосте (без Docker): задать AWG_IFACE, не задавать AWG_DOCKER_CONTAINER
AWG_IFACE=awg0

# SKIP_WG_SET=1 — только сгенерировать конфиг без записи на сервер (отладка)

# Публичный хост для клиентов (если пусто — из WG_ENDPOINT)
PUBLIC_HOST=

# --- Прокси только для Telegram (docker: deploy/docker-compose.telegram-proxy.yml) ---
# Хост для клиентов (если пусто — как PUBLIC_HOST / из WG_ENDPOINT)
# TELEGRAM_PROXY_HOST=
# TELEGRAM_MTPROTO_PORT=8888
# TELEGRAM_MTPROTO_PORT_ALT1=8443
# TELEGRAM_MTPROTO_PORT_ALT2=2053
# TELEGRAM_SOCKS_PORT=64945
# TELEGRAM_SOCKS_PORT_ALT1=64946
# TELEGRAM_SOCKS_PORT_ALT2=64947
# Секрет MTProto (fake TLS): docker run --rm ghcr.io/9seconds/mtg:latest generate-secret www.cloudflare.com
# или свой домен на этот IP. HTTP/SOCKS-прокси для браузера не зависят от этого секрета.
# TELEGRAM_MTPROTO_SECRET=
# Логин/пароль SOCKS5 (обязательна авторизация в контейнере)
# TELEGRAM_SOCKS_USER=
# TELEGRAM_SOCKS_PASSWORD=
# HTTP-прокси для Chrome (GOST в docker-compose; в расширении тип HTTP, не SOCKS5)
# TELEGRAM_HTTP_PROXY_PORT=8086
# TELEGRAM_HTTP_PROXY_USER=
# TELEGRAM_HTTP_PROXY_PASSWORD=

# Имена контейнеров Amnezia и порты (по умолчанию совпадают с типовой установкой)
DOCKER_WIREGUARD_CONTAINER=amnezia-wireguard
DOCKER_OPENVPN_CONTAINER=amnezia-openvpn
DOCKER_OPENVPN_CLOAK_CONTAINER=amnezia-openvpn-cloak
DOCKER_SHADOWSOCKS_CONTAINER=amnezia-shadowsocks
DOCKER_IPSEC_CONTAINER=amnezia-ipsec
DOCKER_XRAY_CONTAINER=amnezia-xray
WIREGUARD_ENDPOINT_PORT=40560
WIREGUARD_CLIENT_PREFIX=10.8.1
OPENVPN_TCP_PORT=49970
CLOAK_EXTERNAL_PORT=443
SHADOWSOCKS_PUBLIC_PORT=46768
# После добавления UUID в Xray контейнер перезапускается (как в клиенте Amnezia). 0/false — не перезапускать (нужен ручной restart)
XRAY_RESTART_CONTAINER=true

# Демоны: при AWG_DOCKER_CONTAINER — DAEMON_WG_INTERFACE=wg0 (имя iface внутри контейнера, dump идёт через docker exec)
DAEMON_WG_INTERFACE=wg0
DAEMON_NET_INTERFACE=eth0
BANDWIDTH_GUARD_LOG=/var/log/vpn_bot_bandwidth_guard.log
TRAFFIC_LOGGER_LOG=/var/log/vpn_bot_traffic_logger.log

# 08:00–08:04 МСК: ежедневный отчёт админу + очистка WG-ключей без активности на awg (дней)
# 0 — не удалять неактивные WG-ключи (пользователи могут вернуться через недели)
STALE_WG_KEY_DAYS=0
# День недели для бэкапа SQLite админу в Telegram: 0=пн … 6=вс
ADMIN_BACKUP_WEEKDAY=0
# Юниты для journalctl -p err в ежедневном дайджесте (через запятую)
ADMIN_JOURNAL_UNITS=vpn-bot.service,vpn-bot-traffic-logger.service,vpn-bot-bandwidth-guard.service

# Алерты админу: диск / + ошибки journalctl по ADMIN_JOURNAL_UNITS (scripts/admin_alerts.py + timer)
# ADMIN_ALERTS_ENABLED=true
# ADMIN_ALERT_DISK_WARN_PCT=12
# ADMIN_ALERT_DISK_CRIT_PCT=7
# ADMIN_ALERT_JOURNAL_WINDOW_MIN=15
# ADMIN_ALERT_JOURNAL_ABS=80
# ADMIN_ALERT_JOURNAL_GROWTH_RATIO=2.0
# ADMIN_ALERT_JOURNAL_GROWTH_FLOOR=20
# ADMIN_ALERT_COOLDOWN_MIN=60

# Опционально: какие Docker-контейнеры проверяет scripts/vpn_bot_healthcheck.py (через запятую).
# По умолчанию — Amnezia + vpn-telegram-mtg/socks5/http-proxy; переопределите, если имена другие.
# VPN_BOT_HEALTHCHECK_CONTAINERS=vpn-telegram-mtg,vpn-telegram-socks5,vpn-telegram-http-proxy,amnezia-awg

# Мягкая проверка WireGuard внутри контейнера (только `wg show … dump`, трафик не трогается).
# Срабатывает, если у ≥ VPN_BOT_HEALTHCHECK_WG_MIN_PEERS peer'ов с handshake все handshake старше VPN_BOT_HEALTHCHECK_WG_STALE_SEC.
# Повтор уведомления не чаще VPN_BOT_HEALTHCHECK_WG_COOLDOWN_MIN (на цель container:iface).
# VPN_BOT_HEALTHCHECK_WG_TARGETS=amnezia-awg:wg0,amnezia-wireguard:wg0
# VPN_BOT_HEALTHCHECK_WG_STALE_SEC=600
# VPN_BOT_HEALTHCHECK_WG_MIN_PEERS=3
# VPN_BOT_HEALTHCHECK_WG_COOLDOWN_MIN=30
# VPN_BOT_HEALTHCHECK_SKIP_WG=1

# PDF-гайды по инструкциям (iOS / Android / Windows): каталог относительно корня проекта или абсолютный путь.
# Ожидаемые имена файлов: ios.pdf, android.pdf, windows.pdf
GUIDES_SRC_DIR=Src

# --- Чеклист VPS (кратко) ---
# 1) Скопировать проект, python3 -m venv venv && pip install -r requirements.txt
# 2) .env: BOT_*, ADMIN_IDS, DATABASE_URL (абсолютный путь к sqlite на сервере)
# 3) chmod +x scripts/generate_peer.sh; WG_* и AWG_IFACE под ваш awg0
# 4) Бот на том же хосте, что awg0, или проброс docker exec / ssh — иначе wg set не сработает
# 5) Первый запуск: python -m vpn_bot (или main.py) — создастся БД; старые peer Amnezia не трогаются
# 6) Опционально: systemd для бота и демонов из deploy/*.service

# Clean Xray (отдельный контейнер, динамическое добавление клиентов через API)
CLEAN_XRAY_CONTAINER=vpn-clean-xray
CLEAN_XRAY_HOST=
CLEAN_XRAY_PORT_VLESS=7443
CLEAN_XRAY_PORT_TROJAN=7444
CLEAN_XRAY_PORT_VMESS=7445
CLEAN_XRAY_PORT_SHADOWSOCKS=7446
CLEAN_XRAY_API_PORT=10085
CLEAN_XRAY_REALITY_PUBLIC_KEY=
CLEAN_XRAY_REALITY_SHORT_ID=
CLEAN_XRAY_REALITY_SERVER_NAME=ok.ru
CLEAN_XRAY_SS_METHOD=chacha20-ietf-poly1305
